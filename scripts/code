#!/bin/bash
# CLI launcher for Mug
# Usage: code [path]
#   code .                 Open current directory
#   code /path/to/dir      Open a directory
#   code /path/to/file.rs  Open a file
#   code                   Open with no args

APP="/Applications/Mug.app"
BIN="$APP/Contents/MacOS/Mug"

if [ ! -x "$BIN" ]; then
  echo "Mug not found at $APP"
  echo "Run ./scripts/deploy to build and install."
  exit 1
fi

if [ -n "$1" ]; then
  # Resolve to absolute path
  TARGET="$(cd "$(dirname "$1")" 2>/dev/null && pwd)/$(basename "$1")"
  "$BIN" "$TARGET" &
else
  "$BIN" &
fi

disown

# Bring the app window to the foreground
open -a "$APP"
